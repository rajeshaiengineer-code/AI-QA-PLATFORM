# ==============================================
# AI QA Platform - Backend Environment Variables
# ==============================================
# Copy this file to .env and update values
# NEVER commit .env to version control
# See docs/ProductionReadiness.md and docs/SecurityChecklist.md
# ==============================================

# Application
APP_NAME=AI QA Platform
APP_VERSION=1.0.0
APP_DESCRIPTION=Enterprise-grade AI-powered Quality Assurance Platform
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# API
API_V1_PREFIX=/api/v1

# Database (PostgreSQL with asyncpg)
# Required. Pool settings apply per uvicorn worker process.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_qa_platform
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# Security
# Production: use a random ≥32 character secret (startup rejects placeholders)
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
# Production recommendation: true (JWT required on protected routes)
AUTH_ENABLED=false

# CORS (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Logging — production: LOG_FORMAT=json
LOG_LEVEL=INFO
LOG_FORMAT=text

# AI Framework (optional — store real keys in a secret manager, not git)
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o-mini
# AI_OPENAI_API_KEY=
# Google Gemini (AI Studio keys may start with AQ. or AIza)
# AI_DEFAULT_PROVIDER=gemini
# AI_DEFAULT_MODEL=gemini-flash-latest
# AI_GEMINI_API_KEY=
# AI_GEMINI_DEFAULT_MODEL=gemini-flash-latest
# AI_CLAUDE_API_KEY=
# Amazon Bedrock bearer API key (not AQ. — generate in AWS Bedrock console)
# AI_DEFAULT_PROVIDER=bedrock
# AI_DEFAULT_MODEL=amazon.nova-lite-v1:0
# AI_BEDROCK_API_KEY=
# AI_BEDROCK_REGION=us-east-1
# AI_BEDROCK_DEFAULT_MODEL=amazon.nova-lite-v1:0

# Notifications
# Email channel logs via SMTP stub (no real SMTP send in MVP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ai-qa-platform.local
SMTP_USE_TLS=true
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
NOTIFICATIONS_PERSIST=true
NOTIFICATIONS_WORKFLOW_HOOK=true
# NOTIFICATIONS_DEFAULT_RECIPIENT=qa@example.com
NOTIFICATIONS_DEFAULT_CHANNEL=email
