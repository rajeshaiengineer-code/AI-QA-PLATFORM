# Same-origin API (Next.js rewrites /api/v1 → BACKEND_URL)
NEXT_PUBLIC_API_URL=/api/v1
BACKEND_URL=http://127.0.0.1:8000
# Optional: pre-fill Create Story form
# NEXT_PUBLIC_DEFAULT_PROJECT_ID=00000000-0000-0000-0000-000000000000

