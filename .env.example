# =====================================================
# AI QA Platform - Environment Configuration (Compose)
# =====================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control
# Secrets guidance: docs/ProductionReadiness.md
# =====================================================

# =====================
# Application
# =====================
ENVIRONMENT=development
DEBUG=true

# =====================
# Ports
# =====================
API_PORT=8000
FRONTEND_PORT=3000
DB_PORT=5432

# =====================
# Database
# =====================
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ai_qa_platform
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# =====================
# Security
# =====================
# Change before any shared/staging/production deploy
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
AUTH_ENABLED=false

# =====================
# CORS
# =====================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =====================
# Frontend
# =====================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# =====================
# Logging
# =====================
LOG_LEVEL=INFO
# text for local; json for staging/production
LOG_FORMAT=text
